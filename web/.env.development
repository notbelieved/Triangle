# Default API origin (matches server PORT=3001). Vite loads this in `npm run dev`.
# Metaplex token metadata URI points here so wallets can GET /api/p/t/:mint (Pyth, avatar, etc.).
VITE_PUBLIC_METADATA_BASE=http://localhost:3001

# Pyth XAU/USD price feed ID (64 hex chars) — used for rwaGOLD deal creation and price display
VITE_XAU_PYTH_FEED_HEX=765d2ba906dbc32ca17cc11f5310a89e9ee1f6420508c63861f2f8ba4ee34bb2

# Devnet mint address of the rwaGOLD token (fill in after running setup-devnet-demo.sh)
VITE_DEMO_RWA_MINT=ANWrxaf2oC4tPheZJ6924L6FnziVcGxPo83c8bNVYTnA
