# Used by scripts/start-mainnet-fork.* — archive-capable mainnet RPC (Helius / Alchemy).
# Do not commit real keys. If a key was pasted in chat, rotate it in the provider dashboard.

# Full URL (preferred):
# MAINNET_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Or only the key (script builds Helius URL):
# HELIUS_API_KEY=YOUR_KEY
